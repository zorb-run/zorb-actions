{
  "name": "@zorb/action-helpers",
  "description": "Shared helpers for authoring zorb actions: input validation, types, test fakes",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "zorb": "^0.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
